# ---------------------------------------------------------------------------
# Live gold-rate providers (SERVER-ONLY — never exposed to the browser)
# Copy this file to `.env.local` and fill in your keys.
# ---------------------------------------------------------------------------

# GoldAPI.io — primary source. ONE key covers gold (XAU), silver (XAG),
# platinum (XPT) and palladium (XPD), each in INR per gram.
# Get a free key at https://www.goldapi.io
GOLDAPI_KEY=

# MetalpriceAPI — secondary source for the same four metals (XAU/XAG/XPT/XPD).
# Also used to derive the live USD->INR rate. Get a free key at
# https://metalpriceapi.com
METALPRICE_API_KEY=

# Note: Bronze and Diamond are NOT spot-traded metals, so they have no live
# ticker. Their per-unit INR baselines live in data/rates/elements/bronze.json
# and data/rates/elements/diamond.json and are maintained manually.

# ---------------------------------------------------------------------------
# Pricing business rules (NOT secret — safe to expose to the storefront).
# These let the client compute the same price the server verifies.
# ---------------------------------------------------------------------------

# Making charges as a % of metal value (Indian retail norm ~8–25%).
NEXT_PUBLIC_MAKING_CHARGE_PCT=12

# Extra profit margin as a % of metal value.
NEXT_PUBLIC_MARGIN_PCT=0

# GST on gold jewellery in India (currently 3%).
NEXT_PUBLIC_GST_PCT=3

# Fallback USD→INR used only for non-gold items when the live rate
# does not provide a conversion.
NEXT_PUBLIC_USD_TO_INR_FALLBACK=83
